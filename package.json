{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun run typecheck && bunx vite build",
    "test": "bun run typecheck",
    "e2e": "./scripts/run-e2e.sh",
    "e2e:teacher": "./scripts/run-e2e.sh teacher",
    "e2e:assistant": "./scripts/run-e2e.sh assistant",
    "e2e:all": "./scripts/run-e2e.sh all",
    "e2e:clean": "./scripts/run-e2e.sh clean",
    "e2e-test:admin": "bunx playwright test --config=playwright.admin.config.ts --grep @admin",
    "e2e-test:admin:headed": "bunx playwright test --config=playwright.admin.config.ts --grep @admin --headed",
    "e2e-test:teacher": "bunx playwright test --config=playwright.teacher.config.ts --grep @teacher",
    "e2e-test:teacher:headed": "bunx playwright test --config=playwright.teacher.config.ts --grep @teacher --headed",
    "e2e-test:assistant": "bunx playwright test --config=playwright.assistant.config.ts --grep @assistant",
    "e2e-test:assistant:headed": "bunx playwright test --config=playwright.assistant.config.ts --grep @assistant --headed",
    "e2e-test:shiyan": "bunx playwright test --config=playwright.shiyan.config.ts --grep @shiyan",
    "e2e-test:shiyan:headed": "bunx playwright test --config=playwright.shiyan.config.ts --grep @shiyan --headed",
    "e2e-test:all": "bun run e2e-test:admin && bun run e2e-test:teacher && bun run e2e-test:assistant && bun run e2e-test:shiyan"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.2.2",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.563.0",
    "react": "^19",
    "react-dom": "^19",
    "react-router": "^7.8.2",
    "react-router-dom": "^7.9.5",
    "recharts": "^3.2.1",
    "swiper": "^12.0.3",
    "tailwindcss": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "vite": "^6.0.7"
  }
}
