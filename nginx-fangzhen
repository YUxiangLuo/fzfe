server {
	listen 80;
	server_name _;

	root /var/www/fangzhen;
	index index.html;

	client_max_body_size 100m;

	location = / {
	    try_files /login.html =404;
	}

	location ^~ /assets/ {
	    try_files $uri =404;
	}

	location ^~ /images/ {
	    try_files $uri =404;
	}

	# Backend APIs and authenticated files are intentionally not proxied here.
	# In the intranet deployment, nginx only serves frontend files; the browser
	# talks to the backend service directly on the same host at port 3001.
	location ^~ /api/ {
	    return 404;
	}
	location ^~ /manuals/ {
	    return 404;
	}
	location ^~ /datasets/ {
	    return 404;
	}
	location ^~ /reports/ {
	    return 404;
	}
	location ^~ /exports/ {
	    return 404;
	}

	location /login {
	    try_files $uri $uri/ /login.html;
	}
	location /admin {
	    try_files $uri $uri/ /admin.html;
	}
	location /teacher {
	    try_files $uri $uri/ /teacher.html;
	}
	location /exp {
	    try_files $uri $uri/ /exp.html;
	}
	location / {
	    try_files $uri $uri/ /index.html;
	}
}
